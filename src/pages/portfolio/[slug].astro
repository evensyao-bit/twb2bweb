const { project } = Astro.props;
---

<Layout 
	title={`${project.title} - 作品案例 - 拓必工作室`}
	description={project.description}
>
	<main class="pt-40 min-h-screen">
		<article class="max-w-7xl mx-auto px-6 py-20">
			<!-- Header Section -->
			<div class="grid lg:grid-cols-2 gap-20 mb-32">
				<div>
					<div class="bg-black text-white text-[10px] font-bold uppercase px-3 py-1 tracking-widest inline-block mb-8">
						{project.category}
					</div>
					<h1 class="text-[clamp(2.5rem,5vw,4.5rem)] font-bold leading-[1.1] tracking-tighter text-black mb-12">
						{project.title}
					</h1>
					
					<div class="space-y-8">
						<div>
							<h3 class="text-[10px] font-bold uppercase tracking-[0.2em] text-black/30 mb-4">專案名稱</h3>
							<div class="flex flex-wrap gap-x-6 gap-y-2">
								{project.projectNames.map(name => (
									<span class="text-lg font-bold text-black/80">{name}</span>
								))}
							</div>
						</div>

            {project.tools && (
              <div>
                <h3 class="text-[10px] font-bold uppercase tracking-[0.2em] text-black/30 mb-4">使用工具</h3>
                <div class="flex flex-wrap gap-3">
                  {project.tools.map(tool => (
                    <span class="px-4 py-2 bg-black/5 rounded-full text-xs font-bold text-black/60">{tool}</span>
                  ))}
                </div>
              </div>
            )}
					</div>
				</div>

				<div class="flex flex-col justify-end">
					<p class="text-xl text-black/60 leading-relaxed mb-12">
						{project.description}
					</p>
					
					<div>
						<h3 class="text-[10px] font-bold uppercase tracking-[0.2em] text-black/30 mb-6">執行重點</h3>
						<ul class="grid sm:grid-cols-2 gap-4">
							{project.highlights.map(item => (
								<li class="flex items-start gap-3 text-sm font-bold text-black/80">
									<svg class="w-4 h-4 text-black mt-0.5 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
										<path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
									</svg>
									{item}
								</li>
							))}
						</ul>
					</div>
				</div>
			</div>

			<!-- Slider Section -->
			<div class="relative group">
				<div class="flex items-center justify-between mb-8">
					<span class="text-[10px] font-bold uppercase tracking-[0.2em] text-black/30">作品</span>
					<div class="flex items-center gap-8">
						<div id="slider-counter" class="text-[10px] font-bold uppercase tracking-[0.2em] text-black/40">
							<span id="current-slide">01</span> / <span id="total-slides">{project.gallery.length.toString().padStart(2, '0')}</span>
						</div>
						<div class="flex gap-4">
							<button id="prev-slide" class="w-12 h-12 bg-white border border-black/5 flex items-center justify-center rounded-full hover:bg-black hover:text-white transition-all shadow-sm">
								<svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
									<path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
								</svg>
							</button>
							<button id="next-slide" class="w-12 h-12 bg-white border border-black/5 flex items-center justify-center rounded-full hover:bg-black hover:text-white transition-all shadow-sm">
								<svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
									<path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
								</svg>
							</button>
						</div>
					</div>
				</div>

				<div id="slider-container" class="flex overflow-x-auto snap-x snap-mandatory scrollbar-hide scroll-smooth gap-4 pb-12">
					{project.gallery.map((img, index) => (
						<div class="min-w-full md:min-w-[80%] snap-center slide-item" data-index={index}>
							<div class="relative bg-black/5 overflow-hidden mb-6 group/item flex justify-center">
								<img 
									src={img.url} 
									alt={img.label} 
									class="w-auto max-w-full h-auto transition-transform duration-1000 group-hover/item:scale-105"
								/>
								<div class="absolute top-6 left-6">
									<span class="bg-black text-white px-4 py-2 text-base font-bold uppercase tracking-widest inline-block">
										{img.label}
									</span>
								</div>
							</div>
						</div>
					))}
				</div>
			</div>

			<!-- Footer Navigation -->
			<div class="mt-32 pt-20 border-t border-black/5 flex justify-between items-center">
				<a href="/portfolio" class="text-xs font-bold uppercase tracking-[0.2em] flex items-center gap-4 group">
					<span class="w-12 h-px bg-black/20 group-hover:w-20 transition-all"></span>
					Back to Portfolio
				</a>
			</div>
		</article>
	</main>
</Layout>

<script>
	function initSlider() {
		const container = document.getElementById('slider-container');
		const prevBtn = document.getElementById('prev-slide');
		const nextBtn = document.getElementById('next-slide');
		const currentDisplay = document.getElementById('current-slide');
		const slides = document.querySelectorAll('.slide-item');

		if (!container || !prevBtn || !nextBtn || !currentDisplay) return;

		const scrollAmount = container.clientWidth * 0.8;

		prevBtn.addEventListener('click', () => {
			container.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
		});

		nextBtn.addEventListener('click', () => {
			container.scrollBy({ left: scrollAmount, behavior: 'smooth' });
		});

		// Intersection Observer for counter
		const observerOptions = {
			root: container,
			threshold: 0.5
		};

		const observer = new IntersectionObserver((entries) => {
			entries.forEach(entry => {
				if (entry.isIntersecting) {
					const index = parseInt(entry.target.getAttribute('data-index')) + 1;
					currentDisplay.textContent = index.toString().padStart(2, '0');
				}
			});
		}, observerOptions);

		slides.forEach(slide => observer.observe(slide));
	}

	initSlider();
	document.addEventListener('astro:after-swap', initSlider);
</script>

<style>
	.scrollbar-hide::-webkit-scrollbar {
		display: none;
	}
	.scrollbar-hide {
		-ms-overflow-style: none;
		scrollbar-width: none;
	}
</style>
