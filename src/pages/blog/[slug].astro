---
import Layout from '../../layouts/Layout.astro';
import { client } from '../../lib/sanity';
import { PortableText } from 'astro-portabletext';

const { slug } = Astro.params;

const post = await client.fetch(`*[_type == "post" && slug.current == $slug][0] {
  "slug": slug.current,
  "mainImage": mainImage.asset->url,
  title,
  "date": publishedAt,
  categories,
  tags,
  author,
  body
}`, { slug });

if (!post) {
  return Astro.redirect('/404');
}

const formatDate = (dateString: string) => {
  if (!dateString) return '';
  return new Date(dateString).toLocaleDateString('zh-TW', {
    year: 'numeric',
    month: '2-digit',
    day: '2-digit'
  }).replace(/\//g, '-');
};
import SanityImage from '../../components/SanityImage.astro';
import YouTube from '../../components/YouTube.astro';
import HtmlBlock from '../../components/HtmlBlock.astro';

const components = {
  type: {
    image: SanityImage,
    youtube: YouTube,
    htmlBlock: HtmlBlock,
  },
  mark: {
    color: ({ children, node }) => {
      return `<span style="color: ${node.hex}">${children}</span>`;
    },
  },
};
---

<Layout title={`${post.title} - 最新文章 - 拓必工作室`}>
	<main class="pt-40 min-h-screen">
		<article class="max-w-4xl mx-auto px-6 py-20">
			<div class="mb-20">
				<div class="flex flex-wrap items-center gap-4 mb-6">
					{post.categories?.map(cat => (
            <a href={`/blog?category=${cat}`} class="bg-black text-white text-[10px] font-bold uppercase px-3 py-1 tracking-widest inline-block">
              {cat}
            </a>
          ))}
				</div>
				<h1 class="text-[clamp(2.5rem,6vw,4.5rem)] font-bold leading-[1.1] tracking-tighter text-black mb-8">
					{post.title}
				</h1>
				<div class="flex items-center gap-4 text-black/40 font-bold text-[10px] uppercase tracking-[0.2em]">
					<span>{formatDate(post.date)}</span>
					<span class="w-1 h-1 bg-black/20 rounded-full"></span>
					<span>Author by {post.author}</span>
				</div>
			</div>
			
			<div class="flex flex-wrap gap-2 mb-10">
				{post.tags?.map(tag => (
					<a href={`/blog?tag=${tag}`} class="text-[10px] font-bold uppercase tracking-widest border border-black/10 px-3 py-2 hover:border-black transition-colors">
						#{tag}
					</a>
				))}
			</div>

			<div class="overflow-hidden bg-[#E8E8E8] aspect-video mb-20">
				<img 
					src={post.mainImage} 
					alt={post.title}
					class="w-full h-full object-cover"
				/>
			</div>

			<div class="prose prose-xl prose-black max-w-none">
				{post.body ? <PortableText value={post.body} components={components} /> : <p>No content available.</p>}
			</div>


		</article>
	</main>
</Layout>
