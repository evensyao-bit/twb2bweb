---
import Layout from '../layouts/Layout.astro';
import { Shield, Mail, Lock, ChevronRight } from 'lucide-astro';

const { searchParams } = Astro.url;
const callbackUrl = searchParams.get('callbackUrl') || '/admin';
const error = searchParams.get('error');
---

<Layout title="Login | 拓必工作室 CMS">
  <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
  <main class="min-h-screen flex items-center justify-center bg-[#0a0a0a] relative overflow-hidden">

    <!-- Animated Background Elements -->
    <div class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] bg-blue-500/10 rounded-full blur-[120px] animate-pulse"></div>
    <div class="absolute bottom-[-10%] right-[-10%] w-[40%] h-[40%] bg-purple-500/10 rounded-full blur-[120px] animate-pulse" style="animation-delay: 2s;"></div>

    <div class="w-full max-w-md p-8 relative z-10">
      <!-- Logo/Brand Section -->
      <div class="text-center mb-8">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-gradient-to-tr from-blue-600 to-purple-600 p-[1px] mb-4 shadow-xl shadow-blue-500/20">
          <div class="w-full h-full bg-[#0f0f0f] rounded-2xl flex items-center justify-center">
            <Shield class="w-8 h-8 text-white" />
          </div>
        </div>
        <h1 class="text-3xl font-bold text-white tracking-tight">CMS Portal</h1>
        <p class="text-gray-400 mt-2">Sign in to manage your content</p>
      </div>

      <!-- Login Form Card -->
      <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-3xl p-8 shadow-2xl overflow-hidden relative group">
        <!-- Shine effect -->
        <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none">
          <div class="absolute top-[-50%] left-[-50%] w-[200%] h-[200%] bg-gradient-to-br from-white/5 to-transparent rotate-45"></div>
        </div>

        {error && (
          <div class="mb-6 p-4 bg-red-500/10 border border-red-500/20 rounded-xl text-red-400 text-sm flex items-start gap-3 animate-shake">
            <div class="mt-0.5">⚠️</div>
            <div>
              <p class="font-semibold">
                {error === 'CredentialsSignin' ? 'Invalid Credentials' : 
                 error.includes('locked') ? 'Account Locked' : 'Authentication Error'}
              </p>
              <p class="opacity-80">
                {error === 'CredentialsSignin' ? 'The email or password you entered is incorrect.' : 
                 error.includes('locked') ? error : 'An unexpected error occurred. Please try again.'}
              </p>
            </div>
          </div>
        )}

        <form id="login-form" class="space-y-6">
          <input type="hidden" name="callbackUrl" value={callbackUrl} />
          
          <div class="space-y-2">
            <label for="email" class="text-sm font-medium text-gray-300 ml-1">Email Address</label>
            <div class="relative">
              <Mail class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-500" />
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full bg-black/40 border border-white/10 rounded-xl py-3.5 pl-12 pr-4 text-white placeholder:text-gray-600 focus:outline-none focus:ring-2 focus:ring-blue-500/40 focus:border-blue-500/50 transition-all"
                placeholder="you@example.com"
              />
            </div>
          </div>

          <div class="space-y-2">
            <label for="password" class="text-sm font-medium text-gray-300 ml-1">Password</label>
            <div class="relative">
              <Lock class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-500" />
              <input
                type="password"
                id="password"
                name="password"
                required
                class="w-full bg-black/40 border border-white/10 rounded-xl py-3.5 pl-12 pr-4 text-white placeholder:text-gray-600 focus:outline-none focus:ring-2 focus:ring-blue-500/40 focus:border-blue-500/50 transition-all"
                placeholder="••••••••"
              />
            </div>
          </div>

          <!-- Honeypot -->
          <div class="hidden">
            <label for="username">Username</label>
            <input type="text" id="username" name="username" tabindex="-1" autocomplete="off" />
          </div>

          <button
            type="submit"
            id="submit-btn"
            class="w-full bg-gradient-to-r from-blue-600 to-purple-600 hover:from-blue-500 hover:to-purple-500 text-white font-bold py-4 rounded-xl shadow-lg shadow-blue-600/20 transform active:scale-[0.98] transition-all flex items-center justify-center gap-2 group/btn"
          >
            Sign In
            <ChevronRight class="w-5 h-5 group-hover/btn:translate-x-1 transition-transform" />
          </button>

          <!-- Cloudflare Turnstile -->
          <div class="flex justify-center mt-4">
            <div 
              class="cf-turnstile" 
              data-sitekey={import.meta.env.PUBLIC_TURNSTILE_SITE_KEY}
              data-theme="dark"
            ></div>
          </div>
        </form>

      </div>

      <p class="text-center mt-8 text-sm text-gray-500">
        &copy; {new Date().getFullYear()} 拓必工作室. All rights reserved.
      </p>
    </div>
  </main>
</Layout>

<script>
  const { signIn } = await import('auth-astro/client');
  
  const form = document.querySelector('#login-form') as HTMLFormElement;
  const submitBtn = document.querySelector('#submit-btn') as HTMLButtonElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    // Honeypot check
    const honeypot = (form.querySelector('#username') as HTMLInputElement).value;
    if (honeypot) return;

    submitBtn.disabled = true;
    submitBtn.innerHTML = '<span class="animate-spin text-xl">◌</span> Signing in...';

    const formData = new FormData(form);
    const email = formData.get('email') as string;
    const password = formData.get('password') as string;
    const callbackUrl = formData.get('callbackUrl') as string;
    const turnstileToken = formData.get('cf-turnstile-response') as string;

    if (!turnstileToken) {
      alert('Please complete the security challenge.');
      submitBtn.disabled = false;
      submitBtn.innerHTML = 'Sign In';
      return;
    }

    try {
      await signIn('credentials', {
        email,
        password,
        callbackUrl,
        turnstileToken,
        redirect: true,
      });

    } catch (err) {
      console.error('Login error:', err);
      window.location.href = `/login?error=CredentialsSignin&callbackUrl=${encodeURIComponent(callbackUrl)}`;
    }
  });
</script>

<style>
  @keyframes shake {
    0%, 100% { transform: translateX(0); }
    25% { transform: translateX(-5px); }
    75% { transform: translateX(5px); }
  }
  .animate-shake {
    animation: shake 0.2s ease-in-out 0s 2;
  }

  input:-webkit-autofill,
  input:-webkit-autofill:hover, 
  input:-webkit-autofill:focus, 
  input:-webkit-autofill:active {
    -webkit-box-shadow: 0 0 0 30px #000 inset !important;
    -webkit-text-fill-color: white !important;
  }
</style>
