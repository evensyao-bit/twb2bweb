---
export const prerender = true;
import Layout from '../layouts/Layout.astro';

const categories = [
  "網站 / 網頁",
  "社群媒體",
  "影音",
  "電子報 / eDM",
  "平面設計"
];

const portfolioItems = [
  {
    id: 1,
    slug: 'website-projects',
    title: "網站建置 Website Projects",
    category: "網站 / 網頁",
    image: "/portfolio/site-1.jpg",
    aspectRatio: "aspect-[4/5]",
    date: "2024-10-30"
  },
  {
    id: 2,
    slug: 'campaign-landing-pages',
    title: "行銷活動網頁設計製作",
    category: "網站 / 網頁",
    image: "/portfolio/new-1.jpg",
    aspectRatio: "aspect-square",
    date: "2024-09-18"
  },
  {
    id: 16,
    slug: 'social-media-marketing',
    title: "社群媒體行銷",
    category: "社群媒體",
    image: "/portfolio/X-1.jpg",
    aspectRatio: "aspect-[4/5]",
    date: "2023-05-30"
  },
  {
    id: 17,
    slug: 'newsletter-marketing',
    title: "電子報行銷 / eDM",
    category: "電子報 / eDM",
    image: "/portfolio/nl-1.jpg",
    aspectRatio: "aspect-[3/4]",
    date: "2023-05-30"
  },
  {
    id: 18,
    slug: 'video-production',
    title: "影音製作",
    category: "影音",
    image: "/portfolio/vd-1.jpg",
    aspectRatio: "aspect-video",
    date: "2024-06-01"
  },
  {
    id: 19,
    slug: 'graphic-design',
    title: "平面設計",
    category: "平面設計",
    image: "/portfolio/Graphic-Brochure.jpg",
    aspectRatio: "aspect-[3/4]",
    date: "2018-08-27"
  },
  {
    id: 20,
    slug: 'deksollc-website',
    title: "零成本高安全的貿易商網站重建",
    category: "網站 / 網頁",
    image: "/portfolio/deksollc-dairy.jpg",
    aspectRatio: "aspect-[3/4]",
    date: "2026-01-28"
  }
].sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
---

<Layout 
  title="作品案例 Portfolio - 拓必工作室 To-Be Studio"
  description="瀏覽拓必工作室的精選作品案例，涵蓋網站建置、行銷活動、社群媒體、影音製作與平面設計。我們協助 B2B 企業打造具備轉換力的數位品牌形象。"
>
	<main class="pt-40 min-h-screen">
		<section class="max-w-7xl mx-auto px-6 py-20">
			<div class="max-w-3xl mb-20">
				<div class="bg-black text-white text-[10px] font-bold uppercase px-3 py-1 tracking-widest inline-block mb-6">
					Case Studies
				</div>
				<h1 class="text-[clamp(3rem,8vw,5.5rem)] font-bold leading-[1.1] tracking-tighter text-black mb-8">
					作品案例
				</h1>
				<p class="text-xl text-black/50 leading-relaxed">
					我們協助不同產業的企業，透過 AI 數位行銷，達成業務成長目標。
				</p>
			</div>

      <!-- Filter Section -->
      <div class="mb-20">
        <div class="flex items-center justify-between mb-8 border-b border-black/5 pb-4">
          <span class="text-[10px] font-bold uppercase tracking-[0.2em] text-black/30">類別</span>
          <button id="reset-portfolio" class="inline-flex items-center gap-2 text-base font-bold uppercase text-black hover:underline group">
            <svg class="w-4 h-4 transition-transform group-hover:-rotate-45" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640"><path fill="currentColor" d="M320 128C263.2 128 212.1 152.7 176.9 192L224 192C241.7 192 256 206.3 256 224C256 241.7 241.7 256 224 256L96 256C78.3 256 64 241.7 64 224L64 96C64 78.3 78.3 64 96 64C113.7 64 128 78.3 128 96L128 150.7C174.9 97.6 243.5 64 320 64C461.4 64 576 178.6 576 320C576 461.4 461.4 576 320 576C233 576 156.1 532.6 109.9 466.3C99.8 451.8 103.3 431.9 117.8 421.7C132.3 411.5 152.2 415.1 162.4 429.6C197.2 479.4 254.8 511.9 320 511.9C426 511.9 512 425.9 512 319.9C512 213.9 426 128 320 128z"/></svg>
            Reset All
          </button>
        </div>
        <div class="flex flex-wrap gap-3">
          {categories.map(cat => (
            <button 
              class="portfolio-filter-btn px-6 py-3 text-xs font-bold tracking-widest uppercase transition-all duration-300 border border-black/10 hover:border-black"
              data-category={cat}
            >
              {cat}
            </button>
          ))}
        </div>
      </div>

			<div id="portfolio-grid" class="columns-1 md:columns-2 lg:columns-3 gap-8 space-y-8">
				{portfolioItems.map((item) => (
					<div class="portfolio-item break-inside-avoid hidden" data-category={item.category}>
						<a href={`/portfolio/${item.slug}`} class="group block">
              <div class={`relative overflow-hidden bg-black/5 ${item.aspectRatio} mb-6`}>
                <img 
                  src={item.image} 
                  alt={item.title}
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                />
                <div class="absolute inset-0 bg-black/20 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
                  <span class="text-white text-[10px] font-bold uppercase tracking-widest border border-white/50 px-4 py-2 backdrop-blur-sm">View Case</span>
                </div>
              </div>
              <div class="flex flex-col gap-2">
                <div class="flex items-center justify-between">
                  <span class="text-[10px] font-bold text-black/30 uppercase tracking-[0.2em]">{item.category}</span>
                  <span class="text-[8px] font-bold text-black/10 uppercase tracking-[0.2em]">{item.date}</span>
                </div>
                <h3 class="text-xl font-bold group-hover:text-black/60 transition-colors">{item.title}</h3>
              </div>
            </a>
					</div>
				))}
			</div>

      <!-- Load More Section -->
      <div class="mt-32 flex flex-col items-center gap-6">
        <button id="load-more-btn" class="group relative px-12 py-5 bg-black text-white text-xs font-bold uppercase tracking-[0.3em] overflow-hidden transition-all hover:pr-16">
          <span class="relative z-10">Load More...</span>
          <div class="absolute inset-0 bg-black/10 translate-y-full group-hover:translate-y-0 transition-transform duration-300"></div>
          <svg class="absolute right-6 top-1/2 -translate-y-1/2 opacity-0 group-hover:opacity-100 transition-all duration-300 w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
        </button>
        <p id="portfolio-stats" class="text-[10px] font-bold text-black/20 uppercase tracking-widest">Showing 6 of 15 items</p>
      </div>
		</section>
	</main>
</Layout>

<script>
  function initPortfolio() {
    const filterButtons = document.querySelectorAll('.portfolio-filter-btn');
    const allItems = Array.from(document.querySelectorAll('.portfolio-item')) as HTMLElement[];
    const resetBtn = document.getElementById('reset-portfolio');
    const loadMoreBtn = document.getElementById('load-more-btn') as HTMLButtonElement;
    const statsDisplay = document.getElementById('portfolio-stats');
    
    let activeFilter = null;
    let visibleCount = 6;
    const increment = 6;

    function applyDisplay() {
      // 1. Filter items based on category
      const filteredItems = allItems.filter(item => {
        const itemCat = item.getAttribute('data-category');
        return !activeFilter || itemCat === activeFilter;
      });

      // 2. Hide all items first
      allItems.forEach(item => item.classList.add('hidden'));

      // 3. Show only up to visibleCount of filtered items
      const itemsToShow = filteredItems.slice(0, visibleCount);
      itemsToShow.forEach(item => item.classList.remove('hidden'));

      // 4. Update Button visibility
      if (visibleCount >= filteredItems.length) {
        loadMoreBtn?.parentElement?.classList.add('hidden');
      } else {
        loadMoreBtn?.parentElement?.classList.remove('hidden');
      }

      // 5. Update Stats
      if (statsDisplay) {
        statsDisplay.textContent = `Showing ${itemsToShow.length} of ${filteredItems.length} items`;
      }

      // 6. Update Button Active States
      filterButtons.forEach(btn => {
        const btnCat = btn.getAttribute('data-category');
        if (btnCat === activeFilter) {
          btn.classList.add('bg-black', 'text-white', 'border-black');
          btn.classList.remove('border-black/10');
        } else {
          btn.classList.remove('bg-black', 'text-white', 'border-black');
          btn.classList.add('border-black/10');
        }
      });
    }

    function loadMore() {
      visibleCount += increment;
      applyDisplay();
    }

    // Event Listeners
    filterButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        const cat = btn.getAttribute('data-category');
        activeFilter = (activeFilter === cat) ? null : cat;
        visibleCount = 6; // Reset on filter change
        applyDisplay();
      });
    });

    resetBtn?.addEventListener('click', () => {
      activeFilter = null;
      visibleCount = 6;
      applyDisplay();
    });

    loadMoreBtn?.addEventListener('click', () => {
      loadMore();
    });

    // Intersection Observer for Infinite Scroll
    if (loadMoreBtn) {
      const observer = new IntersectionObserver((entries) => {
        if (entries[0].isIntersecting) {
          // Add a small delay for better feel or just trigger
          setTimeout(loadMore, 200);
        }
      }, { rootMargin: '100px' }); // Load when button is 100px from viewport bottom

      observer.observe(loadMoreBtn);
    }

    // Initial Display
    applyDisplay();
  }

  // Initialize
  initPortfolio();

  // Handle Astro page transitions
  document.addEventListener('astro:after-swap', initPortfolio);
</script>

<style>
  /* Ensure waterfall items have spacing when stacked in columns */
  .portfolio-item {
    display: inline-block;
    width: 100%;
  }
  /* Explicitly handle hidden state to override the display: inline-block above */
  .portfolio-item.hidden {
    display: none !important;
  }
</style>
